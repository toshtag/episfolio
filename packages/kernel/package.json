{
  "name": "@episfolio/kernel",
  "version": "0.8.0",
  "private": true,
  "description": "Pure TypeScript domain core (no I/O, framework-free)",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
